{
    "version": "0.2.0",
    "inputs": [
        {
            "id": "imagePath",
            "type": "promptString",
            "description": "Path to image file"
        }
    ],
    "configurations": [
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "args": "-f ${input:imagePath} -c .\\config.yaml -o ./out",
            "justMyCode": false
        }
    ]
}
